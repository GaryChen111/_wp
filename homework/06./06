function myFilter(arr, callback) {
    let result = [];

    for (let i = 0; i < arr.length; i++) {
        if (callback(arr[i])) {
            result.push(arr[i]);
        }
    }

    return result;
}

// 測試
const data = [1, 5, 8, 12];

const filtered = myFilter(data, item => item > 7);

console.log(filtered); // [8, 12]
